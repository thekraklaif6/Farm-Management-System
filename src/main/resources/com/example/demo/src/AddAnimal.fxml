<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0" styleClass="root" stylesheets="@add.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.AddAnimalController">
   <children>
      <Pane layoutX="283.0" layoutY="55.0" prefHeight="571.0" prefWidth="574.0" styleClass="main-container">
         <children>
            <Label id="form-title" layoutX="163.0" layoutY="21.0" text="Add new Animal">
               <font>
                  <Font name="Bell MT" size="29.0" />
               </font>
            </Label>
            <Label layoutX="51.0" layoutY="105.0" styleClass="radio" text="Type of animal :">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Spinner fx:id="ageSpinner" layoutX="125.0" layoutY="158.0" />
            <Label layoutX="51.0" layoutY="157.0" text="Age :">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label layoutX="50.0" layoutY="200.0" text="Health status :">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label layoutX="47.0" layoutY="247.0" text="Current weight (KG) :">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label layoutX="45.0" layoutY="291.0" text="Purchase price :">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label layoutX="47.0" layoutY="342.0" prefHeight="27.0" prefWidth="140.0" text="Gender :">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <RadioButton fx:id="cowsRadio" layoutX="209.0" layoutY="110.0" mnemonicParsing="false" text="Cows" />
            <RadioButton fx:id="sheepRadio" layoutX="294.0" layoutY="110.0" mnemonicParsing="false" text="Sheep" />
            <Spinner fx:id="weightSpinner" layoutX="247.0" layoutY="248.0" />
            <RadioButton fx:id="aliveRadio" layoutX="204.0" layoutY="202.0" mnemonicParsing="false" text="alive" />
            <RadioButton fx:id="deadRadio" layoutX="279.0" layoutY="202.0" mnemonicParsing="false" text="Dead" />
            <RadioButton fx:id="sickRadio" layoutX="361.0" layoutY="202.0" mnemonicParsing="false" text="Sick" />
            <Label layoutX="46.0" layoutY="395.0" prefHeight="27.0" prefWidth="318.0" text=" ID of barn:">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label layoutX="44.0" layoutY="442.0" prefHeight="27.0" prefWidth="194.0" text="Date of birth:">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <DatePicker fx:id="dateOfBirthPicker" layoutX="180.0" layoutY="443.0" />
            <Button fx:id="addButton" layoutX="213.0" layoutY="497.0" mnemonicParsing="false" onAction="#handleAddOrUpdateAnimal" prefHeight="43.0" prefWidth="149.0" style="-fx-background-color: #d2b48c; -fx-background-radius: 15; -fx-font-size: 20;" text="+ Add " textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Button>
            <RadioButton fx:id="soldRadio" layoutX="427.0" layoutY="199.0" mnemonicParsing="false" text="Sold" />
            <RadioButton fx:id="maleRadio" layoutX="151.0" layoutY="347.0" mnemonicParsing="false" text="Male" />
            <RadioButton fx:id="femaleRadio" layoutX="243.0" layoutY="347.0" mnemonicParsing="false" text="Famale" />
            <Spinner fx:id="purchasePriceSpinner" layoutX="181.0" layoutY="292.0" prefHeight="25.0" prefWidth="215.0" />
            <ComboBox fx:id="barnComboBox" layoutX="186.0" layoutY="394.0" prefHeight="29.0" prefWidth="173.0" />
            <RadioButton fx:id="goatRadio" layoutX="381.0" layoutY="110.0" mnemonicParsing="false" text="Goat" />
         </children>
      </Pane>
   </children>
</AnchorPane>
