	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Pro.jrdax"/>
	<query language="SQL"><![CDATA[SELECT
    Barn.BarnName,
    Feed.FeedType,
    SUM(Feed.Quantity) AS total_quantity,
    AVG(Feed.MealNumber) AS avg_meals,
    AVG(Feed.Water) AS avg_water
FROM Barn
JOIN Feed ON Barn.BarnID = Feed.BarnID

GROUP BY Barn.BarnName, Feed.FeedType
ORDER BY Barn.BarnName
]]></query>
	<field name="barnname" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="barnname"/>
